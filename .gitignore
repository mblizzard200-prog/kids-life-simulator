# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# *.meta files can be useful as Unity metadata. If you prefer the cleaner 
# GitHub style, or if you have decided to manually manage all the meta files, 
# uncomment the next line
# *.meta

# Logs
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They should only be downloaded in addition to intentionally generated memory captures
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Uncomment this if you have LFS enabled for all binary files
# *.bin filter=lfs diff=lfs merge=lfs -text

# Uncomment this if you want to bypassthe Git pre-commit hook for committing
# with untracked files.
# bSkipSHA = true

/[Bb]uild/
/[Bb]uilds/
/[Dd]ist/
/[Ll]ocal[Bb]uild/
/[Oo]bj/
/[Tt]emp/

# Autogenerated VS/MD solution and project files
ExportedObj/
.csproj
.unityproj
.sln
.suo
.tmp
.user
.userprefs
.pidb
.booproj
.svd
.pdb
.mdb
.opendb
.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.log

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary files
.DS_Store
Thumbs.db